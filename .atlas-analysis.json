  "keyFeatures": [
    "Declarative iptables and ip6tables rule management via Puppet DSL",
    "firewallchain resource for managing custom and built-in chains",
    "Support for NAT (SNAT/DNAT/MASQUERADE), mangle, filter, and raw tables",
    "Rule ordering via numeric prefixes in resource titles",
    "Rule inversion with '!' prefix for parameters",
    "Automatic rule persistence across reboots",
    "Purging of unmanaged firewall rules and chains",
    "ebtables support for bridge firewalling",
    "IPv4 and IPv6 protocol support",
    "Custom Facter facts for iptables version detection"
  ],
  "publicApiSurface": [
    "firewall { 'NNN title': ... } resource type",
    "firewallchain { 'CHAIN:table:protocol': ... } resource type",
    "class firewall (ensure, ensure_v6, pkg_ensure, service_name, package_name, ebtables_manage)",
    "Fact: iptables_version",
    "Fact: ip6tables_version",
    "Fact: iptables_persistent_version"
  ]
